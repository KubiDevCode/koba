generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum YoutubeVideoPrivacyStatus {
  PRIVATE
  UNLISTED
  PUBLIC
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  telegramId String  @unique
  username   String?
  firstName  String?

  role    Role @default(USER)
  respect Int  @default(0)

  entries Entry[]

  chats   Chat[]
  event   Event[]
  eventId String?
}

model Chat {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  telegramId   String  @unique
  title        String?
  avatarFileId String?

  users    User[]
  messages Entry[]
  events   Event[]
}

model Entry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  text String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  chat   Chat   @relation(fields: [chatId], references: [id])
  chatId String
}

model Event {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  title       String   @unique
  description String?
  date        DateTime

  chat   Chat   @relation(fields: [chatId], references: [id])
  chatId String

  photos       Photo[]
  youtubeVideo YouTubeVideo[]

  users User[]
}

model Photo {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fileId String @unique

  event   Event  @relation(fields: [eventId], references: [id])
  eventId String
}

model YouTubeVideo {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  youtubeVideoId String  @unique
  title          String
  description    String?
  privacyStatus  YoutubeVideoPrivacyStatus
  status         String

  watchUrl     String
  embedUrl     String
  thumbnailUrl String?

  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id])
}
